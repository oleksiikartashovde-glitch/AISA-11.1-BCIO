    "prefer_candidate_with_module_consistency",
    "prefer_candidate_with_definition_support",
    "prefer_candidate_from_primary_source_before_supplementary_source",
    "if_still_tied_leave_empty"
  ],
  "source_priority": [
    "bcio_index.json",
    "bcio_by_module.json",
    "bcio_clean.json",
    "BCIO_SEMANTICS_all.json",
    "term_combo_index.json"
  ],
  "final_decision_rule": {
    "rank_candidates_by_score_desc": true,
    "apply_module_gate_after_ranking": true,
    "assign_single_primary_bcio_id_only_if_gate_passes": true,
    "otherwise_leave_empty": true,
    "semantic_expansion_support_must_still_pass_gate": true,
    "if_expansion_only_and_gate_fails_leave_empty": true
  },
  "semantic_expansion_policy": {
    "enabled": true,
    "scope": "candidate_ranking_support_only",
    "trigger_conditions": {
      "top_candidate_confidence_is_low": true,
      "top_candidates_conflict": true,
      "no_strong_exact_or_near_exact_anchor": true
    },
    "limits": {
      "max_synonyms": 3,
      "max_concepts": 2
    },
    "rules": {
      "expansion_must_not_write_final_id": true,
      "expansion_must_not_bypass_gate": true,
      "expansion_must_not_override_literal_fragment": true,
      "expansion_must_not_change_ptrc": true,
      "expansion_results_used_only_to_support_candidate_pool": true,
      "if_no_better_candidate_after_expansion_leave_empty": true
    },
    "priority_order": [
      "literal_anchor",
      "normalized_phrase",
      "synonym_expansion",
      "concept_expansion",
      "ranking",
      "gate"
    ],
    "forbidden_behaviors": [
      "unbounded_expansion",
      "direct_final_id_assignment_from_expansion_only",
      "expansion_without_uncertainty_trigger"
    ]
