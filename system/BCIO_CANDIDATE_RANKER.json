{
  "file_role": "BCIO_CANDIDATE_RANKER",
  "version": "v5.0-index-first-db31",
  "purpose": "Ranking rules for selecting the strongest candidate using bcio_index as the primary routing source and module_position as the primary coordinate layer.",
  "scope": "BCIO ID selection support",
  "ranking_pipeline": [
    "normalized_phrase_retrieval",
    "index_first_candidate_lookup",
    "lexical_anchor_check",
    "definition_support_check",
    "module_position_coordinate_match",
    "optional_hierarchy_nav_narrowing",
    "final_candidate_ranking",
    "problem_layer_compatibility_check",
    "mapping_status_assignment"
  ],
  "global_ranking_rules": {
    "exact_anchor_match_outweighs_near_exact_match": true,
    "near_exact_match_outweighs_semantic_neighbor_only": true,
    "module_consistent_candidate_outweighs_cross_module_candidate": true,
    "hierarchy_consistent_candidate_outweighs_distant_candidate": true,
    "definition_support_strengthens_candidate": true,
    "weak_semantic_match_only_is_penalized": true,
    "methodological_proxy_only_is_penalized": true,
    "empty_preferred_over_low_rank_candidate": true,
    "semantic_expansion_support_allowed_under_uncertainty_only": true,
    "literal_anchor_still_outweighs_expansion": true,
    "module_position_coordinate_match_outweighs_module_name_only_match": true,
    "category_group_subgroup_description_fit_strengthens_candidate": true,
    "index_candidate_outweighs_non_index_candidate": true
  },
  "score_components": {
    "exact_label_match": 100,
    "exact_synonym_match": 95,
    "near_exact_normalized_match": 80,
    "combo_match": 70,
    "definition_anchor_match": 55,
    "module_consistency_bonus": 25,
    "hierarchy_consistency_bonus": 15,
    "semantic_neighbor_bonus": 10,
    "weak_semantic_only_penalty": -40,
    "cross_module_penalty": -35,
    "methodological_proxy_only_penalty": -45,
    "missing_anchor_penalty": -60
  },
  "confidence_tiers": {
    "high": {
      "min_score": 100,
      "description": "Strong lexical anchor and module-consistent candidate."
    },
    "medium": {
      "min_score": 70,
      "description": "Reasonable anchor and acceptable module-consistent match."
    },
    "low": {
      "min_score": 40,
      "description": "Weak but possible candidate; usually leave empty unless gate explicitly allows."
    },
    "reject": {
      "max_score_below": 40,
      "description": "Do not assign BCIO ID."
    }
  },
